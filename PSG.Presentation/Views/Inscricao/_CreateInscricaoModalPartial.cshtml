@* Views/Inscricao/_CreateInscricaoModalPartial.cshtml *@
@using PSG.Domain.Enum
@model PSG.Presentation.Models.Incricao.InscricaoCreateViewModel

<div id="modalNovaInscricao"
     class="fixed inset-0 z-50 flex items-center justify-center">

    @* Backdrop escuro, clicar fora fecha a modal *@
    <div id="modalBackdrop" class="absolute inset-0 bg-black/50"></div>

    <div class="relative bg-white rounded-2xl shadow-lg w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">

        <form id="formNovaInscricao" asp-action="Create" asp-controller="Inscricao" method="post">

            <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
                <h5 class="font-bold text-slate-800">Nova inscrição</h5>
                <button type="button" id="btnFecharModal"
                        class="text-slate-400 hover:text-slate-600 text-xl leading-none">
                    &times;
                </button>
            </div>

            <div class="px-5 py-4 space-y-4">

                <div id="erroGeralInscricao" class="hidden bg-red-50 text-red-600 text-sm rounded-lg px-3 py-2"></div>

                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1.5">Aluno</label>
                    <select asp-for="AlunoId" asp-items="Model.Alunos"
                            class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand">
                        <option value="">Selecione...</option>
                    </select>
                    <span asp-validation-for="AlunoId" class="text-xs text-red-500"></span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1.5">Curso</label>
                        <select asp-for="CursoId" asp-items="Model.Cursos" id="selectCursoModal"
                                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand">
                            <option value="">Selecione...</option>
                        </select>
                        <span asp-validation-for="CursoId" class="text-xs text-red-500"></span>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1.5">Módulo</label>
                        <select asp-for="ModuloId" id="selectModuloModal" disabled
                                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 bg-white disabled:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand">
                            <option value="">Selecione o curso primeiro</option>
                        </select>
                        <span asp-validation-for="ModuloId" class="text-xs text-red-500"></span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1.5">Data de início</label>
                        <input asp-for="DataAcesso" type="date"
                               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand" />
                        <span asp-validation-for="DataAcesso" class="text-xs text-red-500"></span>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1.5">Data de matrícula</label>
                        <input asp-for="DataMatricula" type="date"
                               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1.5">Status</label>
                    <select asp-for="StatusInscricao"
                            asp-items="Html.GetEnumSelectList<EnumStatus>()"
                            class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand">
                    </select>
                </div>

            </div>

            <div class="border-t border-slate-100 px-5 py-4 flex justify-end gap-2">
                <button type="button" id="btnCancelarModal"
                        class="px-4 py-2 rounded-lg text-sm font-semibold text-slate-600 border border-slate-300 hover:bg-slate-50">
                    Cancelar
                </button>
                <button type="submit" id="btnSalvarInscricao"
                        class="inline-flex items-center gap-2 bg-brand hover:bg-brand-dark text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors">
                    <i class="bi bi-check-lg"></i>
                    Salvar
                </button>
            </div>

        </form>
    </div>
</div>