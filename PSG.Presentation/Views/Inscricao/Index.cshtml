@* Helpers: traduzem o EnumStatus em texto e em classes Tailwind (badge/linha) *@
@functions {
    string StatusText(EnumStatus status) => status switch
    {
        EnumStatus.Aprovado => "Aprovado",
        EnumStatus.Reprovado => "Reprovado",
        EnumStatus.EmAndamento => "Andamento",
        EnumStatus.Cancelado => "Cancelado",
        _ => status.ToString()
    };

    string StatusClass(EnumStatus status) => status switch
    {
        EnumStatus.Aprovado => "bg-green-100 text-green-700",
        EnumStatus.Reprovado => "bg-red-100 text-red-600",
        EnumStatus.EmAndamento => "bg-blue-100 text-blue-700",
        EnumStatus.Cancelado => "bg-slate-100 text-slate-500",
        _ => "bg-slate-100 text-slate-500"
    };

    string RowClass(EnumStatus status) => status switch
    {
        EnumStatus.Aprovado => "bg-green-50",
        EnumStatus.Reprovado => "bg-red-50",
        EnumStatus.EmAndamento => "bg-amber-50",
        _ => ""
    };
}

<div id="modalContainer"></div>

@section Scripts {
    <script>
        const modalContainer = document.getElementById('modalContainer');

        document.getElementById('btnNovaInscricao').addEventListener('click', async () => {
            const resp = await fetch('/Inscricao/CreateModal');
            if (!resp.ok) {
                alert('Não foi possível carregar o formulário.');
                return;
            }
            modalContainer.innerHTML = await resp.text();
            document.body.classList.add('overflow-hidden'); // trava o scroll da página atrás da modal
            vincularEventosModal();
        });

        function fecharModal() {
            modalContainer.innerHTML = '';
            document.body.classList.remove('overflow-hidden');
        }

        function vincularEventosModal() {
            const selectCurso = document.getElementById('selectCursoModal');
            const selectModulo = document.getElementById('selectModuloModal');
            const form = document.getElementById('formNovaInscricao');

            document.getElementById('btnFecharModal').addEventListener('click', fecharModal);
            document.getElementById('btnCancelarModal').addEventListener('click', fecharModal);
            document.getElementById('modalBackdrop').addEventListener('click', fecharModal);

            // Fecha com ESC
            document.addEventListener('keydown', function escHandler(e) {
                if (e.key === 'Escape') {
                    fecharModal();
                    document.removeEventListener('keydown', escHandler);
                }
            });

            // Cascata Curso -> Módulo
            selectCurso.addEventListener('change', async () => {
                selectModulo.innerHTML = '<option value="">Carregando...</option>';
                selectModulo.disabled = true;

                const cursoId = selectCurso.value;
                if (!cursoId) {
                    selectModulo.innerHTML = '<option value="">Selecione o curso primeiro</option>';
                    return;
                }

                const resp = await fetch(`/Inscricao/GetModulosPorCursoModal?cursoId=${cursoId}`);
                const modulos = await resp.json();

                selectModulo.innerHTML = '<option value="">Selecione...</option>';
                modulos.forEach(m => {
                    const opt = document.createElement('option');
                    opt.value = m.value;
                    opt.textContent = m.text;
                    selectModulo.appendChild(opt);
                });
                selectModulo.disabled = false;
            });

            // Submit via AJAX
            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                const erroGeral = document.getElementById('erroGeralInscricao');
                erroGeral.classList.add('hidden');

                const btnSalvar = document.getElementById('btnSalvarInscricao');
                btnSalvar.disabled = true;

                const resp = await fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form)
                });

                if (resp.ok) {
                    location.reload();
                    return;
                }

                if (resp.status === 400) {
                    modalContainer.innerHTML = await resp.text();
                    vincularEventosModal();
                } else {
                    erroGeral.textContent = 'Erro inesperado ao salvar. Tente novamente.';
                    erroGeral.classList.remove('hidden');
                    btnSalvar.disabled = false;
                }
            });
        }
    </script>
}