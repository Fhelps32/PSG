@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<aside class="sidebar" id="sidebar">

    <div class="logo">

        <div class="logo-content">
            <i class="bi bi-mortarboard-fill"></i>
            <span>PSG</span>
        </div>

        <button id="toggleSidebar" class="sidebar-toggle">
            <i class="bi bi-list"></i>
        </button>

    </div>

    <ul>

        <li class="@(controller == "Home" ? "active" : "")">
            <a asp-controller="Home" asp-action="Index">
                <i class="bi bi-grid"></i>
                <span>Dashboard</span>
            </a>
        </li>

        <li class="@(controller == "Aluno" ? "active" : "")">
            <a asp-controller="Aluno" asp-action="Index">
                <i class="bi bi-person"></i>
                <span>Alunos</span>
            </a>
        </li>

        <li class="@(controller == "Inscricao" ? "active" : "")">
            <a asp-controller="Inscricao" asp-action="Index">
                <i class="bi bi-journal-text"></i>
                <span>Inscrições</span>
            </a>
        </li>

        <li class="@(controller == "Curso" ? "active" : "")">
            <a asp-controller="Curso" asp-action="Index">
                <i class="bi bi-book"></i>
                <span>Cursos</span>
            </a>
        </li>

        <li class="@(controller == "Modulo" ? "active" : "")">
            <a asp-controller="Modulo" asp-action="Index">
                <i class="bi bi-collection"></i>
                <span>Módulos</span>
            </a>
        </li>

        <li class="@(controller == "Relatorio" ? "active" : "")">
            <a asp-controller="Relatorio" asp-action="Index">
                <i class="bi bi-bar-chart"></i>
                <span>Relatórios</span>
            </a>
        </li>

        <li class="@(controller == "Configuracao" ? "active" : "")">
            <a asp-controller="Configuracao" asp-action="Index">
                <i class="bi bi-gear"></i>
                <span>Configurações</span>
            </a>
        </li>

    </ul>

</aside>

<script>

    const sidebar=document.getElementById("sidebar");

    const btn=document.getElementById("toggleSidebar");

    btn.addEventListener("click",()=>{

        sidebar.classList.toggle("collapsed");

        document.body.classList.toggle("sidebar-collapsed");

    });

</script>