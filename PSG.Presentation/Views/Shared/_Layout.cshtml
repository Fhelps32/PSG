<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PSG</title>

    @* ===== Tailwind CSS via Play CDN (substitui o Bootstrap) ===== *@
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // Tema custom do Tailwind: cor "brand" (azul PSG) + fonte padrão do sistema.
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            DEFAULT: '#2563eb',
                            dark: '#1d4ed8',
                            light: '#eff4ff'
                        }
                    },
                    fontFamily: {
                        sans: ['"Segoe UI"', 'system-ui', 'sans-serif']
                    }
                }
            }
        };
    </script>

    @* Bootstrap Icons continua via CDN (os ícones bi-* usados na sidebar/tela) *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    @* CSS próprio: apenas o mínimo (base + estado da sidebar retrátil). O resto é Tailwind. *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @*
        Restaura o estado (recolhida/expandida) da sidebar ANTES de renderizar o body,
        lendo do localStorage — evita "piscar" a sidebar aberta ao carregar a página.
    *@
    <script>
        if (localStorage.getItem('sidebarCollapsed') === 'true') {
            document.documentElement.classList.add('sidebar-collapsed');
        }
    </script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased">

    @* Sidebar fixa à esquerda *@
    <partial name="_Sidebar" />

    @* Conteúdo principal — a margem esquerda acompanha a largura da sidebar (ver site.css) *@
    <main id="main" class="min-h-screen p-8">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
